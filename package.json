{
  "name": "accessible-react-mentions",
  "private": true,
  "version": "0.0.0",
  "description": "A modern, strictly WCAG 2.2-compliant React mentions library — monorepo root.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "size": "turbo run build --filter=./packages/* && size-limit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=./packages/* && changeset publish",
    "storybook": "pnpm --filter @apps/storybook dev",
    "docs": "pnpm --filter @apps/docs dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/cli": "^2.27.10",
    "@size-limit/preset-small-lib": "^12.1.0",
    "size-limit": "^12.1.0",
    "turbo": "^2.3.0",
    "typescript": "^6.0.3"
  }
}
